# Copy to .env and fill in values used by Makefile, Docker Compose, or scripts.
# PROJECT_NAME=muxyluxy
POSTGRES_DB=roller
POSTGRES_USER=roller
POSTGRES_PASSWORD=roller
DATABASE_URL=postgresql+psycopg://roller:roller@postgres:5432/roller

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Local API (uvicorn/pytest on the host): paths are relative to the repository root
# (run the app from the repo root so ./ansible resolves correctly).
# Docker Compose fixes ANSIBLE_ROOT / ANSIBLE_ROLES_PATH / ANSIBLE_GENERATED_PATH
# inside the api container to /opt/ansible/... — your .env values are not used there.
ANSIBLE_ROOT=./ansible
ANSIBLE_ROLES_PATH=./ansible/roles
ANSIBLE_GENERATED_PATH=./ansible/generated
# Per-run playbook logs (this app). Do not use ANSIBLE_LOG_PATH here — ansible-core
# uses that name for its own log *file* and will error if it points at a directory.
ROLLER_RUN_LOG_DIR=./logs
ANSIBLE_RUN_TIMEOUT_SECONDS=300
