# Copy to .env and fill in values used by Makefile, Docker Compose, or scripts.
# PROJECT_NAME=muxyluxy
POSTGRES_DB=roller
POSTGRES_USER=roller
POSTGRES_PASSWORD=roller
DATABASE_URL=postgresql+psycopg://roller:roller@postgres:5432/roller

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

ANSIBLE_ROOT=/opt/ansible
ANSIBLE_ROLES_PATH=/opt/ansible/roles
ANSIBLE_GENERATED_PATH=/opt/ansible/generated
ANSIBLE_LOG_PATH=/var/log/ansible-roller